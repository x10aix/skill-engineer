{
  "version": "1.0",
  "domains": [
    {
      "name": "core-internal",
      "description": "Interner Skill-Stack (eigene Skills)",
      "paths": [
        "skills/core/internal/",
        "skills/core/forked/"
      ],
      "ecosystem_file": "ECOSYSTEM-internal.md",
      "include_in_global": true
    },
    {
      "name": "core-vendor",
      "description": "Vendor-Skills (extern bezogen, intern eingebunden)",
      "paths": [
        "skills/core/vendor/"
      ],
      "ecosystem_file": "ECOSYSTEM-vendor.md",
      "include_in_global": true
    },
    {
      "name": "clawdbot",
      "description": "ClawdBot-spezifisches Skillset (separate Deployment-Einheit)",
      "paths": [
        "skills/clawdbot/"
      ],
      "ecosystem_file": "ECOSYSTEM-clawdbot.md",
      "include_in_global": false
    }
  ],
  "global_map": {
    "enabled": true,
    "file": "ECOSYSTEM.md",
    "include_domains": ["core-internal", "core-vendor"]
  },
  "unknown_path_policy": "ask"
}
